<?xml version="1.0" encoding="utf-8"?>
<!--
  desktop/installer/close_running_app.wxs

  WiX fragment that terminates a running ClosedMesh.exe (and its child
  process tree, including the bundled node.exe sidecar) before the
  .msi installer starts copying files.

  Why this exists: the same problem the NSIS hook in hooks.nsh solves.
  When a user upgrades while ClosedMesh is running, node.exe is held
  open by the live sidecar — and the installer pops a "file in use"
  dialog. Killing the process tree ahead of the file-copy phase makes
  the upgrade look like a single-click no-op to the user.

  Wiring: the fragment is referenced via tauri.conf.json's
  `bundle.windows.wix.fragmentPaths` + `componentRefs`. The Component
  is a phantom (CreateFolder under TARGETDIR, no payload) that exists
  solely to give the fragment something for componentRefs to reference;
  the real work is the CustomAction + InstallExecuteSequence directives,
  which get linked into the main .msi when the fragment is pulled in.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- Phantom component so `componentRefs: ["CloseRunningApp"]` in
         tauri.conf.json has something to bind against and pulls in
         this fragment (and with it the CustomAction below). -->
    <DirectoryRef Id="TARGETDIR">
      <Component Id="CloseRunningApp"
                 Guid="C7A6F7E4-2A12-4B6E-B7C5-6F8E1A4D9C3E"
                 KeyPath="yes">
        <CreateFolder />
      </Component>
    </DirectoryRef>

    <!-- Two-step kill, in this order:

         1. taskkill /F /T /IM ClosedMesh.exe — force-kills the desktop
            window and its child tree. /T only catches descendants of
            an *alive* parent though, so an orphaned node.exe sidecar
            (left behind by an earlier crash or upgrade) survives this.

         2. PowerShell sweep that finds any node.exe whose path ends
            with \ClosedMesh\node.exe and force-kills it. Path filter
            (not just image name) protects the user's unrelated
            node.exe processes — Node dev servers, VS Code extension
            host, the Electron renderer of another app.

         Return="ignore" on both because either action returns
         non-zero on a clean install (no prior ClosedMesh, no node.exe
         to match) — the expected case, definitely not a reason to
         abort the install. -->
    <CustomAction Id="StopClosedMesh"
                  Directory="TARGETDIR"
                  Execute="immediate"
                  Return="ignore"
                  Impersonate="yes"
                  ExeCommand="&quot;[SystemFolder]taskkill.exe&quot; /F /T /IM ClosedMesh.exe" />

    <CustomAction Id="StopClosedMeshSidecar"
                  Directory="TARGETDIR"
                  Execute="immediate"
                  Return="ignore"
                  Impersonate="yes"
                  ExeCommand="powershell -NoProfile -WindowStyle Hidden -Command &quot;Get-Process -Name node -ErrorAction SilentlyContinue | Where-Object { $_.Path -like '*\ClosedMesh\node.exe' } | Stop-Process -Force -ErrorAction SilentlyContinue&quot;" />

    <!-- Schedule the kills before InstallValidate, which is the phase
         where MSI checks whether any target files are in use. By the
         time InstallValidate runs, ClosedMesh.exe and its node.exe
         sidecar are gone and the file locks have been released. -->
    <InstallExecuteSequence>
      <Custom Action="StopClosedMesh" Before="InstallValidate">1</Custom>
      <Custom Action="StopClosedMeshSidecar" After="StopClosedMesh">1</Custom>
    </InstallExecuteSequence>
  </Fragment>
</Wix>
