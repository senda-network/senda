*.tsbuildinfo
next-env.d.ts

# Internal working files — team framework, strategy notes, research artifacts,
# weekly reports, task ledger, editor/agent tooling configs. Not part of the
# public project; kept out of the public repo. Local tree only.
internal/
# Living Agency command-center artifacts (project charter + ledger) and other
# internal strategy docs — local-only, must never reach the public repo.
.agency/
AGENCY.md
.cursor/rules/agency-state.mdc
docs/confidential-inference.md
# Ignore all Cursor internals except shared agent guidance (rules + skills)
.cursor/*
!.cursor/rules
!.cursor/skills

# Vercel
.vercel/

# Local archives / scratch artifacts the team drops at the repo root.
# Easy to commit by accident on a `git add -A` and bloats history once
# pushed (see commit 657c996 — 6.6 MB Archive.zip slipped through).
*.zip

