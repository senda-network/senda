# OpenAI-compatible base URL for the Senda runtime.
#
# Two common shapes:
#   - Local dev / desktop .app talking to a local senda CLI:
#       SENDA_RUNTIME_URL=http://127.0.0.1:9337/v1
#   - Vercel deployment (senda.network) or a desktop .app pointed at
#     the public mesh entry point (Caddy + auth gateway):
#       SENDA_RUNTIME_URL=https://entry.senda.network/v1
#
# Default if unset: http://127.0.0.1:9337/v1.
SENDA_RUNTIME_URL=http://127.0.0.1:9337/v1

# Senda admin port (used to look up node / topology info).
# For the public deployment, point this at the same gateway:
#   SENDA_ADMIN_URL=https://entry.senda.network
SENDA_ADMIN_URL=http://127.0.0.1:3131

# Bearer token shared with the runtime's auth gateway (Caddy in front of
# the public mesh). Set on Vercel for the senda.network deployment so
# /api/chat and /api/status authenticate to entry.senda.network. Leave
# unset in local dev where the runtime is on the loopback.
# SENDA_RUNTIME_TOKEN=...

# Optional: pin the model id used by /api/chat. If unset, the API picks
# the first model returned by /v1/models.
# SENDA_MODEL=Qwen3-8B-Q4_K_M

# Optional: hard-code the path to the senda binary (used by /control).
# If unset, the API auto-detects from $PATH and standard install dirs.
# SENDA_BIN=/Users/me/.local/bin/senda

# Set NEXT_PUBLIC_DEPLOYMENT=public on the Vercel-hosted deployment so the
# /control page disables itself there (the controller only makes sense
# locally, since it spawns the senda CLI).
# NEXT_PUBLIC_DEPLOYMENT=public

# Origins allowed to call this controller's /api/chat and /api/status
# from the browser (comma-separated). Default: https://senda.network.
# Used when the public site calls back into the local controller running
# at http://127.0.0.1:42141. The current architecture (post-Phase 8b)
# keeps most fetches same-origin, but the CORS layer is still wired up
# for local handoff flows.
# SENDA_PUBLIC_ORIGINS=https://senda.network

# Where the browser-side chat client should send /api/chat when running
# on https://senda.network. Defaults to the desktop sidecar controller
# at http://127.0.0.1:42141.
# NEXT_PUBLIC_LOCAL_CONTROLLER_URL=http://127.0.0.1:42141

# Deprecated fallbacks (still honored for one release): MESH_LLM_URL,
# MESH_CONSOLE_URL, MESH_LLM_MODEL, FORGEMESH_BIN.
